{
  "name": "attachment-reuse-controls-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "wdi5 e2e tests for attachment-reuse-controls",
  "scripts": {
    "test:app1": "wdio run wdio.conf.app1.ts",
    "test:app2": "wdio run wdio.conf.app2.ts",
    "test:app3": "wdio run wdio.conf.app3.ts",
    "test": "npm run test:app1 && npm run test:app2 && npm run test:app3",
    "test:headless": "npm run test:app1 -- --headless && npm run test:app2 -- --headless && npm run test:app3 -- --headless"
  },
  "devDependencies": {
    "@openui5/types": "latest",
    "@types/node": "^20",
    "@wdio/cli": "^9",
    "@wdio/local-runner": "^9",
    "@wdio/mocha-framework": "^9",
    "@wdio/spec-reporter": "^9",
    "ts-node": "^10",
    "typescript": "^5",
    "wdio-ui5-service": "^3"
  }
}
