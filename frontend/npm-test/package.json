{
  "name": "npm-test",
  "version": "0.0.1",
  "description": "An SAP Fiori application for testing npm-installed ui5-upload-controls.",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "dependencies": {
    "ui5-upload-controls": "^1.0.0"
  },
  "devDependencies": {
    "@sap-ux/ui5-middleware-fe-mockserver": "2",
    "@sap/ux-ui5-tooling": "1",
    "@ui5/cli": "^4.0.33"
  },
  "scripts": {
    "start": "fiori run --open \"/test/flpSandbox.html?sap-ui-xx-viewCache=false#npmtest-tile\"",
    "start-local": "fiori run --config ./ui5-local.yaml --open \"/test/flpSandbox.html?sap-ui-xx-viewCache=false#npmtest-tile\"",
    "build": "ui5 build --config=ui5.yaml --clean-dest --dest dist",
    "start-mock": "fiori run --config ./ui5-mock.yaml --open \"/test/flpSandbox.html?sap-ui-xx-viewCache=false#npmtest-tile\"",
    "deploy": "fiori verify",
    "deploy-config": "fiori add deploy-config",
    "start-noflp": "fiori run --open \"/index.html?sap-ui-xx-viewCache=false\"",
    "int-test": "fiori run --config ./ui5-mock.yaml --open \"/test/integration/opaTests.qunit.html\"",
    "start-variants-management": "fiori run --open \"/preview.html?sap-ui-xx-viewCache=false&fiori-tools-rta-mode=true&sap-ui-rta-skip-flex-validation=true#npmtest-tile\""
  },
  "sapuxLayer": "CUSTOMER_BASE",
  "sapux": true,
  "ui5": {
    "dependencies": [
      "ui5-upload-controls"
    ]
  }
}
