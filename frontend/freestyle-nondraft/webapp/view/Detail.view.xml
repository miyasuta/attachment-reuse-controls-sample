<mvc:View controllerName="freestylenondraft.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:upload="miyasuta.ui5uploadcontrols"
    xmlns:form="sap.ui.layout.form">
    <Page id="detailPage" title="Quotation Detail" showNavButton="true" navButtonPress=".onNavBack">
        <headerContent>
            <HBox alignItems="Center" renderType="Bare">
                <Label text="Upload enabled" labelFor="enabledSwitch" class="sapUiTinyMarginEnd"/>
                <Switch id="enabledSwitch" state="{view>/uploadEnabled}" change=".onToggleEnabled"/>
            </HBox>
        </headerContent>
        <content>
            <form:SimpleForm editable="false" layout="ResponsiveGridLayout">
                <form:content>
                    <Label text="ID"/>
                    <Text text="{mainModel>ID}"/>
                    <Label text="Description"/>
                    <Text text="{mainModel>Description}"/>
                    <Label text="File"/>
                    <upload:SingleFileUpload
                        id="singleFileUpload"
                        fileName="{mainModel>fileName}"
                        contentProperty="file"
                        draftOnly="false"
                        enabled="{view>/uploadEnabled}"
                        width="300px"/>
                </form:content>
            </form:SimpleForm>
            <Title text="Attachments" class="sapUiMediumMarginTop sapUiSmallMarginBottom"/>
            <upload:MultiFileUpload
                id="multiFileUpload"
                attachments="{mainModel>attachments}"
                displayProperties="mimeType"
                draftOnly="false"
                enabled="{view>/uploadEnabled}"/>
            <Title text="File Type Filtering (PDF only)" class="sapUiMediumMarginTop sapUiSmallMarginBottom"/>
            <form:SimpleForm editable="false" layout="ResponsiveGridLayout">
                <form:content>
                    <Label text="Single File (PDF only)"/>
                    <upload:SingleFileUpload
                        id="singleFileUploadRestricted"
                        fileName="{mainModel>fileName}"
                        contentProperty="file"
                        draftOnly="false"
                        enabled="{view>/uploadEnabled}"
                        fileTypes="pdf"
                        width="300px"/>
                </form:content>
            </form:SimpleForm>
            <upload:MultiFileUpload
                id="multiFileUploadRestricted"
                attachments="{mainModel>attachments}"
                displayProperties="mimeType"
                draftOnly="false"
                enabled="{view>/uploadEnabled}"
                fileTypes="pdf"/>
        </content>
    </Page>
</mvc:View>
