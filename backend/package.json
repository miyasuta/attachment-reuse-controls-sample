{
  "name": "backend",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/attachments": "^3.9.0",
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-npm-test": "cds watch --open npmtest/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/npm-test"
  ],
  "cds": {
    "requires": {
      "[production]": {
        "auth": "dummy",
        "db": "hana"
      },
      "attachments": {
          "kind": "db",
          "scan": false
      } 
    }
  }
}
